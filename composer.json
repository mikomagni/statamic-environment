{
    "name": "mikomagni/statamic-environment",
    "version": "2.0.0",
    "type": "statamic-addon",
    "license": "MIT",
    "homepage": "https://graffio.co",
    "description": "Statamic Environment Indicator and Dashboard Widget for Statamic 6",
    "keywords": [
        "statamic",
        "addon",
        "environment",
        "indicator",
        "development"
    ],
    "autoload": {
        "psr-4": {
            "MikoMagni\\StatamicEnvironment\\": "src"
        }
    },
    "require": {
        "php": "^8.3",
        "statamic/cms": "^6.0"
    },
    "extra": {
        "statamic": {
            "name": "Statamic Environment Indicator",
            "description": "Statamic Environment Indicator and Dashboard Widget"
        },
        "laravel": {
            "providers": [
                "MikoMagni\\StatamicEnvironment\\ServiceProvider"
            ]
        },
        "publish": {
            "css": "public/vendor/statamic-environment/css"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pixelfear/composer-dist-plugin": true
        }
    }
}
